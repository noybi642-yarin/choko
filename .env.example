# Anthropic API key — required for the support chat backend
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use for support chat (default: claude-haiku-4-5)
# SUPPORT_MODEL=claude-haiku-4-5

# Production frontend origin for CORS (e.g. https://choko.app)
# FRONTEND_ORIGIN=https://choko.app

# Port for the Express server (default: 3001)
# PORT=3001
